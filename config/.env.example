# Copy this file to .env and fill in your values
# cp config/.env.example config/.env

# --- Database ---
DB_PATH=data/sportsbetting.db

# --- SportsGameOdds (Player Props) ---
# Get a key at https://sportsgameodds.com
SPORTSGAMEODDS_API_KEY=6edcd54d81979d8211ff76ecc1dfa31e

# --- The Odds API ---
# Get a free key at https://the-odds-api.com
ODDS_API_KEY=6edcd54d81979d8211ff76ecc1dfa31e

# --- NBA API ---
# No key required - uses the public NBA.com stats API
# Optionally tune request delays to avoid rate limiting
NBA_API_DELAY=3.0

# --- Ingestion Settings ---
# How many seasons of historical data to pull (e.g. 2023-24, 2022-23)
NBA_SEASONS=2025-26,2024-25

# --- Logging ---
LOG_LEVEL=INFO
