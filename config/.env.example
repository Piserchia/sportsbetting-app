# Copy this file to .env and fill in your values
# cp config/.env.example config/.env

# --- Database ---
DB_PATH=data/sportsbetting.db

# --- The Odds API ---
# Get a free key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# --- NBA API ---
# No key required - uses the public NBA.com stats API
# Optionally tune request delays to avoid rate limiting
NBA_API_DELAY=1.0

# --- Ingestion Settings ---
# How many seasons of historical data to pull (e.g. 2023-24, 2022-23)
NBA_SEASONS=2024-25,2023-24,2022-23

# --- Logging ---
LOG_LEVEL=INFO
